{
  "name": "meetjoshi-portfolio-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=packages/frontend",
    "build:backend": "npm run build --workspace=packages/backend",
    "build:shared": "npm run build --workspace=packages/shared",
    "test": "npm run test --workspaces --if-present",
    "docker:build-frontend": "docker build -f packages/frontend/Dockerfile -t meetjoshi-frontend:latest .",
    "docker:build-backend": "docker build -f packages/backend/Dockerfile -t meetjoshi-backend:latest .",
    "docker:build-all": "npm run docker:build-frontend && npm run docker:build-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "~5.9.3"
  }
}
