{
  "name": "meet-joshi---portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "preview": "ng serve --configuration=production",
    "docker:build": "docker build -t meetjoshi-portfolio:latest .",
    "docker:run": "docker run -p 8080:8080 meetjoshi-portfolio:latest",
    "docker:build-run": "npm run docker:build && npm run docker:run",
    "gcp:build": "gcloud builds submit --tag gcr.io/PROJECT_ID/meetjoshi-portfolio",
    "gcp:deploy": "gcloud run deploy meetjoshi-portfolio --image gcr.io/PROJECT_ID/meetjoshi-portfolio --platform managed --region us-central1 --allow-unauthenticated"
  },
  "dependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.6",
    "@supabase/supabase-js": "^2.89.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
