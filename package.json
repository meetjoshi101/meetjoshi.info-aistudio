{
  "name": "meetjoshi-portfolio-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "nx run-many -t serve --parallel=2",
    "dev:frontend": "nx serve frontend",
    "dev:backend": "nx serve backend",
    "build": "nx run-many -t build --all",
    "build:frontend": "nx build frontend",
    "build:backend": "nx build backend",
    "build:shared": "nx build shared",
    "test": "nx run-many -t test --all",
    "test:frontend": "nx test frontend",
    "test:backend": "nx test backend",
    "test:shared": "nx test shared",
    "lint": "nx run-many -t lint --all",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "docker:build-frontend": "docker build -f apps/frontend/Dockerfile -t meetjoshi-frontend:latest .",
    "docker:build-backend": "docker build -f apps/backend/Dockerfile -t meetjoshi-backend:latest .",
    "docker:build-all": "npm run docker:build-frontend && npm run docker:build-backend"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.1.0",
    "@angular-eslint/template-parser": "^21.1.0",
    "@nx/angular": "^22.3.3",
    "@nx/eslint": "^22.3.3",
    "@nx/eslint-plugin": "^22.3.3",
    "@nx/jest": "^22.3.3",
    "@nx/js": "^22.3.3",
    "@nx/node": "^22.3.3",
    "@nx/vite": "^22.3.3",
    "@nx/workspace": "^22.3.3",
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "concurrently": "^9.1.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "16.0.0",
    "nx": "^22.3.3",
    "playwright": "^1.57.0",
    "ts-jest": "^29.2.3",
    "typescript": "~5.9.3"
  }
}
